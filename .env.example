# Django Configuration
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production

# Database (automatically set by Railway/Render or leave empty for SQLite)
DATABASE_URL=

# CORS - Update with your frontend domain after deployment
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Optional: Individual database settings (ignored if DATABASE_URL is set)
DB_ENGINE=sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
